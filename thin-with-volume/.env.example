# Copy this file to ".env" and fill in your real values.
# ".env" is git-ignored and must NEVER be committed.
#
# METHOD B (thin + volume): tokens are used at RUNTIME on the pod to download
# models onto the network volume on first boot. Set them as env vars on the
# RunPod Template (this file is just a reference of what's needed).

# --- Used at RUNTIME on the pod (set on the RunPod Template) ---
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx          # HuggingFace read token (gated FLUX.2 [dev])
CIVITAI_TOKEN=xxxxxxxxxxxxxxxxxxxx         # CivitAI API key
WEB_PASSWORD=choose-a-strong-password      # gates FileBrowser / Kohya / Jupyter / code-server

# --- Used only when BUILDING + pushing the thin image ---
DOCKERHUB_USER=your-dockerhub-username     # lowercase Docker Hub username
