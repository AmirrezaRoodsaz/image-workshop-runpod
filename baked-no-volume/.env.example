# Copy this file to ".env" and fill in your real values.
# ".env" is git-ignored and must NEVER be committed.
#
# These are used ONLY during the build (on the build pod) and at runtime
# on the RunPod Template. They are never baked into the image layers.

# --- Build-time secrets (used on the build pod) ---
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx          # HuggingFace read token (gated FLUX.2 [dev])
CIVITAI_TOKEN=xxxxxxxxxxxxxxxxxxxx         # CivitAI API key
DOCKERHUB_USER=your-dockerhub-username     # lowercase Docker Hub username

# --- Runtime (set on the RunPod Template, not here) ---
WEB_PASSWORD=choose-a-strong-password      # gates FileBrowser / Kohya / Jupyter / code-server
